# Backend Configuration Variables

# Database configuration
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/rentova
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=postgres

# Email Configuration (SMTP)
# Create an App Password in your Google Account:
# 1. Go to Google Account -> Security
# 2. Enable 2-Step Verification
# 3. Go to App Passwords
# 4. Generate an App Password for "Mail"
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_new_app_password

# JWT Secret
# JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_256_bits_long
